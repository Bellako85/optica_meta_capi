<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_config_settings_meta_capi" model="ir.ui.view">
        <field name="name">res.config.settings.meta.capi</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">

                <app data-string="Meta CAPI" string="Meta CAPI" name="meta_capi">
                    <block title="Meta Conversions API">
                        <setting string="Enable Meta CAPI">
                            <field name="meta_capi_enabled"/>
                        </setting>

                        <setting string="Meta Pixel ID">
                            <field name="meta_pixel_id"/>
                        </setting>

                        <setting string="Meta Access Token">
                            <field name="meta_access_token" password="True"/>
                        </setting>

                        <setting string="Meta Test Event Code">
                            <field name="meta_test_event_code"/>
                        </setting>
                    </block>
                </app>

            </xpath>
        </field>
    </record>
</odoo>
