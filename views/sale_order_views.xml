<odoo>
    <record id="view_order_form_meta_capi_button" model="ir.ui.view">
        <field name="name">sale.order.form.meta.capi.button</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_send_purchase_to_meta"
                        type="object"
                        string="Enviar Purchase a Meta"
                        class="btn-primary"
                        attrs="{'invisible': [('x_meta_purchase_sent', '=', True)]}"/>
            </xpath>

            <xpath expr="//sheet/notebook" position="inside">
                <page string="Meta CAPI">
                    <group>
                        <group>
                            <field name="x_meta_purchase_sent" readonly="1"/>
                            <field name="x_meta_purchase_event_id" readonly="1"/>
                            <field name="x_meta_order_link_opened" readonly="1"/>
                            <field name="x_meta_order_link_opened_at" readonly="1"/>
                        </group>
                        <group>
                            <field name="x_meta_fbp" readonly="1"/>
                            <field name="x_meta_fbc" readonly="1"/>
                            <field name="x_meta_client_ip" readonly="1"/>
                            <field name="x_meta_user_agent" readonly="1"/>
                            <field name="x_meta_event_source_url" readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
